generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Level {
  principiante
  intermedio
  avanzado
}

enum Category {
  movilidad
  estiramientos
  fortalecimiento
}

enum MovementType {
  controlado
  dinamico
  pendular
  estatico
  isometrico
}

enum Position {
  sentado
  de_pie
  cuatro_puntos
  acostado_supino
  acostado_prono
  inclinado
}

enum Equipment {
  sin_equipo
  pared
  banda_elastica
  pesas_ligeras
}

enum UserRole {
  ADMIN
  FISIOTERAPEUTA
  PACIENTE
}

model ExerciseGroup {
  id        String   @id @default(cuid())
  groupId   String
  category  Category
  exercises Exercise[]
  createdAt DateTime @default(now())
  
  @@unique([groupId, category])
  @@index([groupId])
}

model Exercise {
  id              String   @id
  name            String
  videoUrl        String   @db.Text
  level           Level
  movementType    MovementType
  position        Position
  equipment       Equipment

  metrics         Json
  targetMuscles   Json

  groupId         String
  group           ExerciseGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  tags            ExerciseTagRelation[]
  recommendations RecommendedExercise[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([groupId])
}

model ExerciseTag {
  id        String   @id @default(cuid())
  name      String   @unique
  exercises ExerciseTagRelation[]
  
  @@index([name])
}

model ExerciseTagRelation {
  exerciseId String
  tagId      String

  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  tag        ExerciseTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([exerciseId, tagId])
  @@index([tagId])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // hashed con bcryptjs
  name      String
  role      UserRole

  // Relación 1-a-1: solo si es PACIENTE
  fisioId   String?
  fisio     User?    @relation("PatientFisio", fields: [fisioId], references: [id], onDelete: SetNull)
  patients  User[]   @relation("PatientFisio")

  // Recomendaciones que recibe (solo PACIENTE)
  recommendations ExerciseRecommendation?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
  @@index([fisioId])
}

model ExerciseRecommendation {
  id        String   @id @default(cuid())
  patientId String   @unique
  exercises RecommendedExercise[]

  patient   User     @relation(fields: [patientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RecommendedExercise {
  id               String   @id @default(cuid())
  recommendationId String
  exerciseId       String
  order            Int

  recommendation   ExerciseRecommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  exercise         Exercise               @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([recommendationId, exerciseId])
  @@index([recommendationId])
  @@index([exerciseId])
}